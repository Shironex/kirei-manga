{
  "name": "@kireimanga/bubble-detector",
  "version": "0.3.0",
  "private": true,
  "description": "KireiManga C++ speech-bubble detector (node-addon-api + OpenCV)",
  "main": "index.js",
  "gypfile": true,
  "scripts": {
    "install": "node-gyp-build || true",
    "build": "node-gyp rebuild",
    "prebuild": "prebuildify --napi --strip && node scripts/rename-prebuild.mjs",
    "build:opencv:posix": "bash scripts/build-opencv.sh",
    "build:opencv:win": "pwsh scripts/build-opencv.ps1"
  },
  "dependencies": {
    "node-addon-api": "^8.6.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "prebuildify": "^6.0.1"
  }
}
