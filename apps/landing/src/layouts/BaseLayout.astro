---
import BaseHead from '../components/BaseHead.astro';
import { LANDING_VERSION } from '../lib/site';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <script is:inline define:vars={{ version: LANDING_VERSION }}>
      window.__kireimanga = { version };
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link" data-i18n="layout.skipToContent">Skip to content</a>
    <div class="page-shell">
      <div class="paper-grain" aria-hidden="true"></div>
      <slot />
    </div>

    <script>
      function initReveal() {
        const els = document.querySelectorAll('.reveal:not(.is-visible)');
        if (!els.length) return;

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '-40px' },
        );

        els.forEach((el) => observer.observe(el));
      }

      initReveal();
    </script>

    <script>
      import { translations, type LandingLanguage } from '../lib/i18n';

      const LANG_KEY = 'kireimanga.language';
      const kireiWindow = window as Window & {
        __kireimanga?: { version: string };
      };
      const version = kireiWindow.__kireimanga?.version ?? '';

      function getStoredLang(): LandingLanguage {
        const stored = localStorage.getItem(LANG_KEY);
        if (stored === 'en' || stored === 'pl') return stored;
        return 'en';
      }

      function interpolate(template: string): string {
        return template.replace(/\{version\}/g, version);
      }

      /**
       * Applies translations keyed by data-i18n* attributes. The `data-i18n-html`
       * path uses innerHTML to support inline markup (e.g. the hero title's <em>
       * and <br>). Values come exclusively from our static i18n dictionary at
       * build time — no user input flows here — so there is no XSS surface.
       */
      function applyTranslations(lang: LandingLanguage) {
        const dict = translations[lang];
        if (!dict) return;

        document.documentElement.lang = lang;

        document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
          const key = el.dataset.i18n;
          if (!key) return;
          const value = dict[key];
          if (value != null) el.textContent = interpolate(value);
        });

        document.querySelectorAll<HTMLElement>('[data-i18n-html]').forEach((el) => {
          const key = el.dataset.i18nHtml;
          if (!key) return;
          const value = dict[key];
          // eslint-disable-next-line no-unsanitized/property -- static dict, not user input
          if (value != null) el.innerHTML = interpolate(value);
        });

        document.querySelectorAll<HTMLElement>('[data-i18n-alt]').forEach((el) => {
          const key = el.dataset.i18nAlt;
          if (!key) return;
          const value = dict[key];
          if (value != null) el.setAttribute('alt', interpolate(value));
        });

        document.querySelectorAll<HTMLElement>('[data-i18n-aria-label]').forEach((el) => {
          const key = el.dataset.i18nAriaLabel;
          if (!key) return;
          const value = dict[key];
          if (value != null) el.setAttribute('aria-label', interpolate(value));
        });

        document.querySelectorAll<HTMLElement>('[data-lang-toggle]').forEach((btn) => {
          btn.textContent = lang === 'en' ? 'PL' : 'EN';
        });
      }

      function initI18n() {
        applyTranslations(getStoredLang());

        document.querySelectorAll('[data-lang-toggle]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const current = getStoredLang();
            const next: LandingLanguage = current === 'en' ? 'pl' : 'en';
            localStorage.setItem(LANG_KEY, next);
            applyTranslations(next);
          });
        });
      }

      initI18n();
    </script>
  </body>
</html>
