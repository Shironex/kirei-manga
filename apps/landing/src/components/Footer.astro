---
import { GITHUB_REPO_URL, GITHUB_RELEASES_URL, LANDING_VERSION } from '../lib/site';
---

<footer class="footer">
  <div class="section">
    <div class="footer-grid">
      <div>
        <div class="brand" style="gap: 0.55rem;">
          <span class="hanko" aria-hidden="true">綺</span>
          <div>
            <div class="brand-name">KireiManga</div>
            <div class="eyebrow" style="margin-top: 2px;" data-i18n="footer.tagline">
              Read any manga, in any language.
            </div>
          </div>
        </div>
        <p
          style="margin: 1.2rem 0 0; max-width: 36ch; color: var(--color-muted-foreground); font-size: 0.88rem; line-height: 1.65;"
          data-i18n="footer.body"
        >
          A local first desktop manga reader with MangaDex browsing, CBZ and folder
          import, offline reading, and translation tools on the roadmap.
        </p>
      </div>

      <div>
        <h4 data-i18n="footer.project">Project</h4>
        <ul class="footer-list">
          <li>
            <a href={GITHUB_REPO_URL} target="_blank" rel="noopener noreferrer" data-i18n="footer.source">
              Source on GitHub
            </a>
          </li>
          <li>
            <a href={GITHUB_RELEASES_URL} target="_blank" rel="noopener noreferrer" data-i18n="footer.releases">
              Releases
            </a>
          </li>
          <li>
            <a href="/changelog" data-i18n="footer.changelog">
              Changelog
            </a>
          </li>
          <li>
            <a href={`${GITHUB_REPO_URL}/issues`} target="_blank" rel="noopener noreferrer" data-i18n="footer.issue">
              Report an issue
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4 data-i18n="footer.sisterApps">Sister apps</h4>
        <ul class="footer-list">
          <li><a href="https://shiroani.app/" target="_blank" rel="noopener noreferrer">白アニ · ShiroAni</a></li>
          <li><a href="https://shiranami.app/" target="_blank" rel="noopener noreferrer">白波 · Shiranami</a></li>
        </ul>
      </div>

      <div class="footer-colophon">
        <div>
          <span data-i18n="footer.colophon">Source available · v{LANDING_VERSION} · Built by</span>
          {' '}
          <a
            href="https://github.com/Shironex"
            target="_blank"
            rel="noopener noreferrer"
            style="color: var(--color-foreground); text-decoration: underline; text-decoration-color: var(--color-accent); text-underline-offset: 3px;"
          >Shironex</a>
        </div>
        <div class="kanji">綺麗漫画</div>
      </div>
    </div>
  </div>
</footer>
