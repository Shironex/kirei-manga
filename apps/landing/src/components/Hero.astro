---
import { Image } from 'astro:assets';
import { GITHUB_REPO_URL, LANDING_VERSION } from '../lib/site';
import mascotRead from '../assets/mascot-read.png';
---

<section class="hero section" id="top">
  <div class="hero-ornament" aria-hidden="true">綺麗</div>

  <div class="hero-grid">
    <div class="hero-body reveal">
      <div class="hero-eyebrow">
        <span class="eyebrow eyebrow--accent" data-i18n="hero.eyebrowBrand">綺麗漫画 · KireiManga</span>
        <span class="rule" aria-hidden="true"></span>
        <span class="eyebrow" data-i18n="hero.eyebrowMilestone">v{LANDING_VERSION} · Local Library</span>
      </div>

      <h1 class="hero-title" data-i18n-html="hero.titleHtml">
        Read any manga,<br />in <em>any</em> language.
      </h1>

      <p class="hero-subhead" data-i18n="hero.subhead">
        A quiet desktop reader built around your own library. Browse MangaDex, keep your
        collection in SQLite, and read CBZ files or folders in one calm reading space.
        No dashboard clutter. No neon. Just a shelf you will want to return to.
      </p>

      <div class="hero-cta">
        <a class="btn btn-primary" href="/download">
          <span data-i18n="hero.ctaDownload">Download v{LANDING_VERSION}</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 3v12m0 0l-4-4m4 4l4-4M5 21h14" />
          </svg>
        </a>
        <a class="btn btn-ghost" href={GITHUB_REPO_URL} target="_blank" rel="noopener noreferrer">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12Z"/>
          </svg>
          <span data-i18n="hero.ctaGithub">View on GitHub</span>
        </a>
      </div>

      <div class="hero-meta">
        <span data-i18n="hero.metaWindows">Windows</span>
        <span class="dot" aria-hidden="true"></span>
        <span data-i18n="hero.metaMacos">macOS</span>
        <span class="dot" aria-hidden="true"></span>
        <span data-i18n="hero.metaLicense">Source available</span>
      </div>
    </div>

    <div class="hero-frame reveal">
      <aside class="tate-inner" aria-hidden="true" data-i18n="hero.tate">静かに読む場所</aside>
      <figure class="hero-portrait">
        <Image src={mascotRead} alt="Kirei reading quietly" widths={[320, 480, 640]} sizes="(max-width: 768px) 60vw, 22rem" loading="eager" data-i18n-alt="hero.portraitAlt" />
        <figcaption class="hero-portrait-caption">
          <span data-i18n="hero.portraitCaption">Plate 0 · Frontispiece</span>
          <span class="kanji" aria-hidden="true">綺麗</span>
        </figcaption>
      </figure>
    </div>
  </div>
</section>
