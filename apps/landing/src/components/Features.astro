---
interface FeatureItem {
  num: string;
  kanji: string;
  key: string;
  title: string;
  body: string;
  tag?: string;
}

const features: FeatureItem[] = [
  {
    num: '01',
    kanji: '漫画帳',
    key: '01',
    title: 'MangaDex Browse',
    body: "Discovery tabs for Popular, Latest, and Top rated, plus search across title, author, tags, demographic, and rating through MangaDex's official API.",
  },
  {
    num: '02',
    kanji: '書棚',
    key: '02',
    title: 'Library',
    body: 'Keep follow status, reading status, and chapter progress for MangaDex series and local series in one place.',
  },
  {
    num: '03',
    kanji: '取込',
    key: '03',
    tag: 'v0.2',
    title: 'Local Import',
    body: 'Pick a folder, scan CBZ, ZIP, and image based series, review the matches, and import everything in one pass.',
  },
  {
    num: '04',
    kanji: '読書',
    key: '04',
    title: 'Distraction free Reader',
    body: 'Read in full screen with single page, double page, or webtoon layouts, fit controls, keyboard navigation, RTL support, and cached pages from disk.',
  },
  {
    num: '05',
    kanji: '栞',
    key: '05',
    title: 'Bookmarks and Progress',
    body: 'Save page bookmarks with notes and resume exactly where you stopped, whether the chapter is local, remote, or already downloaded for offline reading.',
  },
  {
    num: '06',
    kanji: '翻訳',
    key: '06',
    tag: 'v0.3',
    title: 'Translation Overlay',
    body: 'Bubble detection, manga OCR, and DeepL, Google, or Ollama translations can be rendered directly on the page for raw Japanese releases.',
  },
  {
    num: '07',
    kanji: '同期',
    key: '07',
    tag: 'v0.4',
    title: 'AniList Sync',
    body: 'Sign in with OAuth, import your list, and keep reading progress in sync between the app and AniList.',
  },
  {
    num: '08',
    kanji: '言葉',
    key: '08',
    title: 'English and Polish',
    body: 'The interface is available in English and Polish, with language switching built in from the start.',
  },
];
---

<section class="section section-stack" id="features">
  <div class="section-head reveal">
    <div>
      <div class="section-label">
        <span class="num" data-i18n="features.num">§ I</span>
        <span class="eyebrow" data-i18n="features.label">Contents</span>
      </div>
      <h2 data-i18n="features.heading">Everything a reader needs, nothing that gets in the way.</h2>
    </div>
    <p data-i18n="features.body">
      KireiManga is shaped around how people actually read manga, one folder at a time
      and one chapter at a time. The feature set stays restrained on purpose. It is
      there when you need it and quiet when you do not.
    </p>
  </div>

  <div class="toc reveal-stagger">
    {features.map(feature => (
      <article class="toc-item reveal">
        <div class="toc-num">{feature.num}</div>
        <div class="toc-title">
          <span class="kanji" aria-hidden="true">{feature.kanji}</span>
          <h3>
            <span data-i18n={`features.${feature.key}.title`}>{feature.title}</span>
            {feature.tag && <span class="toc-tag">{feature.tag}</span>}
          </h3>
        </div>
        <p class="toc-body" data-i18n={`features.${feature.key}.body`}>{feature.body}</p>
      </article>
    ))}
  </div>
</section>
