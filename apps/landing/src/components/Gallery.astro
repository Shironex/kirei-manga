---
import { Image } from 'astro:assets';
import libraryShot from '../assets/screenshots/library.png';
import seriesShot from '../assets/screenshots/series.png';
import importShot from '../assets/screenshots/import.png';
import readerShot from '../assets/screenshots/reader.png';

const plates = [
  {
    num: 'Pl. I',
    key: '01',
    title: 'Library',
    note: 'A calm shelf with fast search, filters, and lazy cover loading that stays smooth even with a large collection.',
    src: libraryShot,
    alt: 'KireiManga library view with covers in a clean grid',
    span: 'plate-span-7',
  },
  {
    num: 'Pl. II',
    key: '02',
    title: 'Series Detail',
    note: 'Synopsis, chapters, follow status, and reading direction stay together on one clean page.',
    src: seriesShot,
    alt: 'Series detail page showing synopsis and chapter list',
    span: 'plate-span-5',
  },
  {
    num: 'Pl. III',
    key: '03',
    title: 'Local Import',
    note: 'Choose a folder, scan archives or image folders, review metadata, and confirm the import.',
    src: importShot,
    alt: 'Local import review screen',
    span: 'plate-span-6',
  },
  {
    num: 'Pl. IV',
    key: '04',
    title: 'Reader',
    note: 'Full screen reading with fit controls, keyboard navigation, and per series reading direction.',
    src: readerShot,
    alt: 'KireiManga reader in full screen mode',
    span: 'plate-span-6',
  },
] as const;
---

<section class="section section-stack" id="gallery">
  <div class="section-head reveal">
    <div>
      <div class="section-label">
        <span class="num" data-i18n="gallery.num">§ II</span>
        <span class="eyebrow" data-i18n="gallery.label">Gallery</span>
      </div>
      <h2 data-i18n="gallery.heading">A set of quiet screens.</h2>
    </div>
    <p data-i18n="gallery.body">
      These screenshots come from the current build. Each view is meant to stay
      clear, readable, and out of the way while you browse or read.
    </p>
  </div>

  <div class="plate-grid reveal-stagger">
    {plates.map(plate => (
      <figure class={`plate reveal ${plate.span}`}>
        <div class="plate-frame">
          <Image src={plate.src} alt={plate.alt} data-i18n-alt={`gallery.${plate.key}.alt`} widths={[480, 768, 1024, 1280]} sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 720px" loading="lazy" />
        </div>
        <figcaption class="plate-caption">
          <div>
            <h3 class="plate-title" data-i18n={`gallery.${plate.key}.title`}>{plate.title}</h3>
            <p class="plate-note" data-i18n={`gallery.${plate.key}.note`}>{plate.note}</p>
          </div>
          <span class="plate-num">{plate.num}</span>
        </figcaption>
      </figure>
    ))}
  </div>
</section>
