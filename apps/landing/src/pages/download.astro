---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import { GITHUB_RELEASES_LATEST_URL, LANDING_VERSION } from '../lib/site';
---

<BaseLayout
  title="Download KireiManga"
  description="Download the latest KireiManga desktop build for Windows or macOS."
>
  <Navbar />
  <main id="main" class="section subpage">
    <a href="/" class="subpage-back" data-i18n="changelog.backHome">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M15 18l-6-6 6-6" />
      </svg>
      <span>Back to home</span>
    </a>

    <div class="subpage-header reveal">
      <div>
        <div class="section-label">
          <span class="num" data-i18n="cta.num">§ IV</span>
          <span class="eyebrow eyebrow--accent" data-i18n="download.label">Download</span>
        </div>
        <h1 data-i18n="download.heading">Pick the build that fits your desk.</h1>
      </div>
      <p data-i18n="download.subtitle">
        KireiManga ships unsigned for now. SmartScreen will grumble on Windows;
        macOS will block the first open. Both are one click (or one Terminal command) past.
      </p>
    </div>

    <div class="download-grid reveal-stagger" id="download-grid">
      <a
        class="download-card reveal"
        data-platform="win"
        href={GITHUB_RELEASES_LATEST_URL}
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="download-glyph" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M0 3.449L9.75 2.1v9.451H0zm0 17.1L9.75 22v-9.351H0zM10.949 22L24 19.93V12.75H10.949zM10.949 2.1v9.451H24V2.1z"/>
          </svg>
        </span>
        <span class="download-meta">
          <span class="download-platform">
            <span data-i18n="download.windows">Windows</span>
            <span class="download-badge" data-platform-badge style="display:none;" data-i18n="download.yourSystem">Your system</span>
          </span>
          <span class="download-ext" data-i18n="download.windowsExt">.exe installer</span>
        </span>
        <span class="download-cta">
          v{LANDING_VERSION}
        </span>
      </a>

      <a
        class="download-card reveal"
        data-platform="mac"
        href={GITHUB_RELEASES_LATEST_URL}
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="download-glyph" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
          </svg>
        </span>
        <span class="download-meta">
          <span class="download-platform">
            <span data-i18n="download.macos">macOS</span>
            <span class="download-badge" data-platform-badge style="display:none;" data-i18n="download.yourSystem">Your system</span>
          </span>
          <span class="download-ext" data-i18n="download.macosExt">.dmg disk image</span>
        </span>
        <span class="download-cta">
          v{LANDING_VERSION}
        </span>
      </a>
    </div>

    <a
      href={GITHUB_RELEASES_LATEST_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-ghost reveal"
      style="margin-top: 1.5rem;"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12Z"/>
      </svg>
      <span data-i18n="download.open">Open Releases on GitHub</span>
    </a>

    <section class="download-note reveal">
      <h2 data-i18n="download.notesTitle">If your OS complains…</h2>

      <div class="download-note-row">
        <div class="download-note-label" data-i18n="download.windows">Windows</div>
        <p class="download-note-body" data-i18n="download.notesWindows">
          Windows SmartScreen will warn on first run because the installer isn't
          code-signed. Click 'More info', then 'Run anyway'.
        </p>
      </div>

      <div class="download-note-row">
        <div class="download-note-label" data-i18n="download.macos">macOS</div>
        <div>
          <p class="download-note-body" data-i18n="download.notesMacos">
            macOS will block the first launch because the .dmg isn't notarised.
            Drag the app to Applications, then open Terminal and run:
          </p>
          <code class="download-note-cmd" data-i18n="download.notesMacosCmd">xattr -cr /Applications/KireiManga.app</code>
        </div>
      </div>

      <div class="download-note-row">
        <div class="download-note-label">Source</div>
        <p class="download-note-body" data-i18n="download.notesSource">
          Rather build from source? Clone the repo, run pnpm install, then
          pnpm package:win or pnpm package:mac.
        </p>
      </div>
    </section>
  </main>
  <Footer />

  <script is:inline>
    (function () {
      var ua = navigator.userAgent.toLowerCase();
      var platform = 'win';
      if (ua.indexOf('mac') !== -1) platform = 'mac';
      if (ua.indexOf('linux') !== -1) platform = null;

      var grid = document.getElementById('download-grid');
      if (!grid || !platform) return;

      var primary = grid.querySelector('[data-platform="' + platform + '"]');
      if (!primary) return;

      primary.classList.add('is-primary');
      primary.parentNode.insertBefore(primary, grid.firstChild);

      var badge = primary.querySelector('[data-platform-badge]');
      if (badge) badge.style.display = 'inline-block';
    })();
  </script>
</BaseLayout>
