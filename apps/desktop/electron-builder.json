{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.shironex.kireimanga",
  "productName": "KireiManga",
  "directories": {
    "output": "release",
    "buildResources": "resources"
  },
  "files": ["dist/**/*", "package.json", "!**/*.map", "!**/*.d.ts", "!dist/**/*.d.ts"],
  "extraResources": [
    {
      "from": "../web/dist",
      "to": "renderer",
      "filter": ["**/*"]
    },
    {
      "from": "resources/icon.ico",
      "to": "icon.ico"
    },
    {
      "from": "resources/icon.png",
      "to": "icon.png"
    },
    {
      "from": "resources/icon-16.png",
      "to": "icon-16.png"
    },
    {
      "from": "resources/icon-32.png",
      "to": "icon-32.png"
    },
    {
      "from": "resources/licenses",
      "to": "licenses"
    }
  ],
  "asarUnpack": [
    "**/node_modules/better-sqlite3/**",
    "**/build/Release/*.node",
    "**/node_modules/@kireimanga/bubble-detector/prebuilds/**/*.node"
  ],
  "artifactName": "${productName}-${version}-${arch}.${ext}",
  "nodeGypRebuild": false,
  "npmRebuild": false,
  "publish": {
    "provider": "github",
    "owner": "Shironex",
    "repo": "kirei-manga"
  },
  "mac": {
    "category": "public.app-category.entertainment",
    "target": ["dmg"],
    "icon": "resources/icon.png"
  },
  "win": {
    "target": ["nsis"],
    "icon": "resources/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  },
  "electronFuses": {
    "runAsNode": false,
    "enableNodeCliInspectArguments": false,
    "enableNodeOptionsEnvironmentVariable": false,
    "onlyLoadAppFromAsar": true
  }
}
