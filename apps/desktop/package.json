{
  "name": "@kireimanga/desktop",
  "version": "0.1.0",
  "description": "KireiManga desktop application",
  "author": {
    "name": "Shironex"
  },
  "homepage": "https://github.com/Shironex/kirei-manga",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "predev": "node ../../scripts/native-build.mjs",
    "dev": "node esbuild.config.mjs && cross-env NODE_ENV=development electron .",
    "build:dev": "node esbuild.config.mjs",
    "build": "pnpm native:build && node esbuild.config.mjs",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:watch": "jest --watch",
    "package": "pnpm build && electron-builder",
    "package:win": "pnpm build && electron-builder --win",
    "package:mac": "pnpm build && electron-builder --mac",
    "native:build": "node ../../scripts/native-build.mjs",
    "native:clean": "node-gyp clean",
    "postinstall": "electron-builder install-app-deps || true",
    "rebuild": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@kireimanga/shared": "workspace:*",
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/platform-socket.io": "^11.1.16",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.16",
    "better-sqlite3": "^12.6.2",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "image-size": "^2.0.2",
    "mime-types": "^3.0.2",
    "node-addon-api": "^8.6.0",
    "node-stream-zip": "^1.15.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "semver": "^7.7.4",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@anatine/esbuild-decorators": "^0.2.19",
    "@electron/rebuild": "^4.0.3",
    "@nestjs/testing": "^11.1.16",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.5.0",
    "@types/semver": "^7.7.1",
    "@types/sql.js": "^1.4.9",
    "cross-env": "^10.1.0",
    "electron": "^40.8.5",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "jest": "^30.3.0",
    "jszip": "^3.10.1",
    "sql.js": "^1.10.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
